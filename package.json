{
  "name": "open-mic-vue-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "cdk:install": "cd cdk && npm install",
    "cdk:synth": "cd cdk && npx cdk synth",
    "cdk:diff": "cd cdk && npx cdk diff",
    "cdk:deploy": "cd cdk && npx cdk deploy --require-approval never",
    "cdk:destroy": "cd cdk && npx cdk destroy",
    "deploy": "npm run build && npm run cdk:deploy",
    "deploy:full": "npm run cdk:install && npm run build && npm run cdk:deploy"
  },
  "dependencies": {
    "@primevue/themes": "^4.3.9",
    "amazon-cognito-identity-js": "^6.3.15",
    "pinia": "^3.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.9",
    "qrcode": "^1.5.4",
    "vue": "^3.5.21",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.8.3",
    "vite": "^7.1.7",
    "vue-tsc": "^3.0.7"
  }
}
